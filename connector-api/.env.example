# Connector API Configuration
# Copy to .env and fill in actual values

# Server port
PORT=3001

# JWT secret for token signing (change in production!)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Node environment
NODE_ENV=development

# Allowed origins (CORS)
# For development: chrome-extension://* and moz-extension://*
# For production: specify exact extension IDs
ALLOWED_ORIGINS=chrome-extension://*,moz-extension://*

# Provider API Keys (optional - can be stored securely instead)
# GEMINI_API_KEY=your-gemini-key
# CLAUDE_API_KEY=your-claude-key
# CHATGPT_API_KEY=your-chatgpt-key

# Database URL (for production)
# DATABASE_URL=postgresql://user:password@localhost/connector_api

# Logging level
LOG_LEVEL=info
