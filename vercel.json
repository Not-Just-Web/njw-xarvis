{
  "buildCommand": "cd connector-api && npm install && npm run build",
  "outputDirectory": "connector-api/dist",
  "installCommand": "yarn install && cd connector-api && npm ci",
  "env": {
    "NODE_ENV": "production",
    "JWT_SECRET": "@jwt_secret",
    "ALLOWED_ORIGINS": "chrome-extension://*,moz-extension://*"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
