{
  "buildCommand": "yarn build:chromium",
  "outputDirectory": "dist/chromium",
  "installCommand": "yarn install",
  "env": {
    "NODE_ENV": "production",
    "ALLOWED_ORIGINS": "chrome-extension://*,moz-extension://*"
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/extension/sidepanel.html"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
