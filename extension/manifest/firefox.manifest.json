{
  "manifest_version": 2,
  "name": "njw-xarvis",
  "version": "0.2.0",
  "description": "njw-xarvis: Sidepanel AI chat with browser context capture.",
  "permissions": ["storage", "activeTab", "tabs", "contextMenus", "<all_urls>"],
  "browser_action": {
    "default_title": "njw-xarvis",
    "default_popup": "extension/popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "njw-xarvis",
    "default_panel": "extension/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "njw-xarvis@notjustweb.dev"
    }
  }
}
