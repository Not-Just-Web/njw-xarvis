{
  "manifest_version": 2,
  "name": "NJW Xarvis",
  "version": "0.2.0",
  "description": "NJW Xarvis: AI assistant sidepanel with browser context capture.",
  "permissions": ["storage", "activeTab", "tabs", "contextMenus", "<all_urls>"],
  "browser_action": {
    "default_title": "NJW Xarvis",
    "default_popup": "extension/popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "NJW Xarvis",
    "default_panel": "extension/sidepanel.html"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open NJW Xarvis sidepanel"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "njw-xarvis@notjustweb.dev"
    }
  }
}
