{
  "manifest_version": 3,
  "name": "NJW Xarvis",
  "version": "0.2.0",
  "description": "NJW Xarvis: AI assistant sidepanel with browser context capture.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "NJW Xarvis",
    "default_popup": "extension/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "extension/sidepanel.html"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open NJW Xarvis sidepanel"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
