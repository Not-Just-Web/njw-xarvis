{
  "manifest_version": 3,
  "name": "AI Assistant Extension",
  "version": "0.2.0",
  "description": "Sidepanel AI assistant with browser context capture.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "AI Assistant",
    "default_popup": "extension/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "extension/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
