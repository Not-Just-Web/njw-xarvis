{
  "name": "njw-xarvis",
  "version": "1.0.3",
  "private": true,
  "description": "njw-xarvis: Cross-browser AI sidepanel extension - Chat with AI with live browser context",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "connector-api"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env TARGET=chromium vite build --watch",
    "dev:api": "cd connector-api && yarn dev",
    "dev:all": "concurrently \"yarn dev\" \"yarn dev:api\"",
    "build:chromium": "cross-env TARGET=chromium vite build",
    "build:firefox": "cross-env TARGET=firefox vite build",
    "build": "yarn build:chromium && yarn build:firefox",
    "build:all": "yarn build && cd connector-api && yarn build",
    "build:api": "cd connector-api && yarn build",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "cd connector-api && yarn typecheck",
    "typecheck:all": "yarn typecheck && yarn typecheck:api",
    "lint": "eslint .",
    "lint:api": "cd connector-api && yarn lint",
    "lint:all": "yarn lint && yarn lint:api",
    "test": "vitest run --config vitest.config.ts",
    "test:api": "cd connector-api && yarn test",
    "test:all": "yarn test && yarn test:api",
    "validate:all": "yarn typecheck:all && yarn lint:all && yarn test:all && yarn build:all",
    "setup": "yarn install && cd connector-api && yarn install && cd ..",
    "prepare": "husky install"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vitest": "^3.1.3"
  }
}
